# Public site URL (used for SEO, sitemap, RSS, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://rupaligupta.com

# Formspree form IDs (create 3 free forms at https://formspree.io -> use the part after /f/)
NEXT_PUBLIC_FORMSPREE_SPEAKING=xxxxxxxx
NEXT_PUBLIC_FORMSPREE_ADVISORY=xxxxxxxx
NEXT_PUBLIC_FORMSPREE_MEDIA=xxxxxxxx

# beehiiv newsletter URLs + embeddable subscribe form src (Publication > Settings > Embed)
NEXT_PUBLIC_BEEHIIV_AIPULSE_URL=https://your-aipulse.beehiiv.com
NEXT_PUBLIC_BEEHIIV_AIPULSE_EMBED=https://embeds.beehiiv.com/your-aipulse-id
NEXT_PUBLIC_BEEHIIV_PLATFORMPATH_URL=https://your-platformpath.beehiiv.com
NEXT_PUBLIC_BEEHIIV_PLATFORMPATH_EMBED=https://embeds.beehiiv.com/your-platformpath-id

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA_ID=

# Notion CMS (optional). If set, blog posts are read from Notion instead of /content/posts.
# Requires the optional packages: npm i @notionhq/client notion-to-md
NOTION_TOKEN=
NOTION_DATABASE_ID=
